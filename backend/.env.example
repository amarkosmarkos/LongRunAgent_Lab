# Copy to .env. If ANTHROPIC_API_KEY is unset, the lab runs in mock mode.
ANTHROPIC_API_KEY=
# Force mock mode even with a key set (1 = mock)
LLM_MOCK=
# Models per agent role (optional overrides)
MODEL_PLANNER=claude-sonnet-4-6
MODEL_STRATEGIST=claude-sonnet-4-6
MODEL_EXPERIMENTER=claude-sonnet-4-6
MODEL_CRITIC=claude-haiku-4-5-20251001
MODEL_SUPERVISOR=claude-sonnet-4-6
